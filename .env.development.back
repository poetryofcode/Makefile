PORT=3000 # port for container for backend

DB_HOST=todo-db-container # data base name for db container
DB_PORT=5432 # standart port for Postgress image
DB_USER=todo # name for user for Postgress 
DB_PASSWORD=todo # password for user for Postgress
DB_NAME=todo # name of Postgress data base 

CORS_ORIGIN=http://localhost:18080 # backend will allow request from this front
